<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:upeko.ViewModels"
             xmlns:conv="using:upeko.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="900"
             x:Class="upeko.Views.BotView"
             x:DataType="vm:BotViewModel">

    <UserControl.Resources>
        <conv:StatusToDotColorConverter x:Key="StatusDotColor"/>
        <conv:StatusToPillBackgroundConverter x:Key="StatusPillBg"/>
        <conv:StatusToPillForegroundConverter x:Key="StatusPillFg"/>
        <conv:NullToStringConverter x:Key="NullToStr"/>
    </UserControl.Resources>

    <StackPanel Spacing="0">
        <!-- Back Button -->
        <Button Classes="btn-ghost" HorizontalAlignment="Left" Margin="0,0,0,24"
                Command="{Binding GoBackCommand}" Padding="0" MinHeight="0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Viewbox Width="16" Height="16">
                    <Path Data="M15 19L8 12L15 5"
                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                          StrokeLineCap="Round" StrokeJoin="Round"/>
                </Viewbox>
                <TextBlock Text="Back to Instances" FontSize="13"
                           Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>
        </Button>

        <!-- Header Section -->
        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                Padding="0,0,0,32" Margin="0,0,0,40">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Avatar (clickable to change) -->
                <Border Grid.Column="0" Width="80" Height="80" CornerRadius="8"
                        Background="{DynamicResource TertiaryBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        Margin="0,0,24,0"
                        ClipToBounds="True">
                    <Panel>
                        <TextBlock Text="{Binding DisplayInitial}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextTertiary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Button Background="Transparent"
                                Width="80" Height="80"
                                Padding="0"
                                BorderThickness="0"
                                CornerRadius="8"
                                Cursor="Hand"
                                Command="{Binding ChangeAvatarCommand}"
                                ToolTip.Tip="Click to change avatar"/>
                    </Panel>
                </Border>

                <!-- Name + Meta -->
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="4">
                    <!-- Name display with edit mode -->
                    <Grid>
                        <!-- Regular name display (click to edit) -->
                        <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,2"
                                   IsVisible="{Binding !IsEditingName}"
                                   Cursor="Hand"
                                   Tapped="OnNameTapped"
                                   ToolTip.Tip="Click to rename"/>

                        <!-- Name editing mode -->
                        <StackPanel Orientation="Horizontal" IsVisible="{Binding IsEditingName}"
                                    Margin="0,0,0,2">
                            <TextBox Text="{Binding EditedName}"
                                     MinWidth="200"
                                     FontSize="20"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding SaveNameCommand}"/>
                                    <KeyBinding Gesture="Escape" Command="{Binding CancelEditNameCommand}"/>
                                </TextBox.KeyBindings>
                            </TextBox>
                            <Button Classes="btn-ghost" Padding="6" Margin="4,0,0,0"
                                    Command="{Binding SaveNameCommand}"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Save">
                                <Viewbox Width="16" Height="16">
                                    <Path Data="M20 6L9 17L4 12"
                                          Stroke="{DynamicResource AccentColor}" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                </Viewbox>
                            </Button>
                            <Button Classes="btn-ghost" Padding="6" Margin="2,0,0,0"
                                    Command="{Binding CancelEditNameCommand}"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Cancel">
                                <Viewbox Width="16" Height="16">
                                    <Path Data="M18 6L6 18M6 6L18 18"
                                          Stroke="{DynamicResource TextTertiary}" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="{DynamicResource TertiaryBackground}"
                                CornerRadius="4" Padding="8,2">
                            <TextBlock Text="{Binding Bot.Guid}" FontSize="11"
                                       FontFamily="JetBrains Mono,Consolas,monospace"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Version" FontSize="13"
                                       Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="{Binding Version, Converter={StaticResource NullToStr}}"
                                       FontSize="13"
                                       FontFamily="JetBrains Mono,Consolas,monospace"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Status Pill -->
                <Border Grid.Column="2" VerticalAlignment="Center"
                        CornerRadius="999" Padding="10,4"
                        Background="{Binding State, Converter={StaticResource StatusPillBg}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8"
                                 Fill="{Binding State, Converter={StaticResource StatusDotColor}}"/>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{Binding State, Converter={StaticResource StatusPillFg}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content Grid -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column -->
            <StackPanel Grid.Column="0" Spacing="24">
                <!-- Configuration Card -->
                <Border Classes="card">
                    <StackPanel>
                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                                Padding="16">
                            <TextBlock Text="Configuration" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </Border>
                        <Border Padding="16">
                            <StackPanel Spacing="16">
                                <!-- Path input -->
                                <StackPanel Spacing="6">
                                    <TextBlock Text="INSTALL PATH" FontSize="11" FontWeight="Medium"
                                               Foreground="{DynamicResource TextSecondary}"
                                               LetterSpacing="1"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0" Classes="input" IsReadOnly="True"
                                                 Text="{Binding BotPath}"
                                                 FontFamily="JetBrains Mono,Consolas,monospace"
                                                 FontSize="11"/>
                                        <Button Grid.Column="1" Classes="btn-ghost" Content="Browse"
                                                Command="{Binding BrowsePathCommand}"
                                                Margin="8,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Actions Card -->
                <Border Classes="card">
                    <StackPanel>
                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                                Padding="16">
                            <TextBlock Text="Actions" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </Border>

                        <!-- Action Buttons -->
                        <Border Padding="16" IsVisible="{Binding !IsProgressVisible}">
                            <StackPanel>
                                <!-- Running: Stop button -->
                                <Button Classes="btn-danger" IsVisible="{Binding IsRunning}"
                                        Content="Stop Instance"
                                        Command="{Binding StopBotCommand}"
                                        HorizontalAlignment="Stretch"/>

                                <!-- Ready: Start + Update -->
                                <Grid ColumnDefinitions="*,8,*" IsVisible="{Binding IsReady}">
                                    <Button Grid.Column="0" Classes="btn-primary"
                                            Content="Start"
                                            Command="{Binding StartBotCommand}"
                                            HorizontalAlignment="Stretch"/>
                                    <Button Grid.Column="2" Classes="btn-ghost"
                                            Command="{Binding UpdateBotCommand}"
                                            IsEnabled="{Binding !IsCheckingForUpdates}"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    HorizontalAlignment="Center">
                                            <Viewbox Width="14" Height="14">
                                                <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4A8 8 0 0 0 4 12A8 8 0 0 0 12 20C15.73 20 18.84 17.45 19.73 14H17.65C16.83 16.33 14.61 18 12 18A6 6 0 0 1 6 12A6 6 0 0 1 12 6C13.66 6 15.14 6.69 16.22 7.78L13 11H20V4L17.65 6.35Z"
                                                      Fill="{DynamicResource TextSecondary}"/>
                                            </Viewbox>
                                            <TextBlock Text="{Binding UpdateButtonText}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Missing: Download -->
                                <Button Classes="btn-primary" IsVisible="{Binding IsMissing}"
                                        Content="Download &amp; Install"
                                        Command="{Binding DownloadBotCommand}"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>

                        <!-- Progress Panel -->
                        <Border Padding="16" IsVisible="{Binding IsProgressVisible}">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding ProgressTitle}"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ProgressPercent}"
                                               FontSize="13"
                                               FontFamily="JetBrains Mono,Consolas,monospace"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </Grid>
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}"
                                             Height="6" CornerRadius="3"
                                             Foreground="{DynamicResource AccentColor}"
                                             Background="{DynamicResource TertiaryBackground}"/>
                                <TextBlock Text="{Binding ProgressDetail}" FontSize="11"
                                           Foreground="{DynamicResource TextTertiary}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right Column (Sidebar) -->
            <StackPanel Grid.Column="2" Spacing="24">
                <!-- Shortcuts Card -->
                <Border Classes="card">
                    <StackPanel>
                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                                Padding="16">
                            <TextBlock Text="Shortcuts" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </Border>
                        <Border Padding="8">
                            <StackPanel Spacing="0">
                                <!-- Data Folder -->
                                <Button Classes="shortcut-btn" Command="{Binding OpenFolderCommand}">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Viewbox Grid.Column="0" Width="20" Height="20" Margin="0,0,12,0">
                                            <Path Data="M3 7V17A2 2 0 0 0 5 19H19A2 2 0 0 0 21 17V9A2 2 0 0 0 19 7H13L11 5H5A2 2 0 0 0 3 7Z"
                                                  Stroke="{DynamicResource TextTertiary}" StrokeThickness="1.5"
                                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                                        </Viewbox>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="Data Folder" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="Open in file manager" FontSize="11"
                                                       Foreground="{DynamicResource TextTertiary}"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <!-- Creds -->
                                <Button Classes="shortcut-btn" Command="{Binding OpenCredsCommand}">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Viewbox Grid.Column="0" Width="20" Height="20" Margin="0,0,12,0">
                                            <Path Data="M9 12H15M9 16H15M17 21H7A2 2 0 0 1 5 19V5A2 2 0 0 1 7 3H12.586A1 1 0 0 1 13.293 3.293L18.707 8.707A1 1 0 0 1 19 9.414V19A2 2 0 0 1 17 21Z"
                                                  Stroke="{DynamicResource TextTertiary}" StrokeThickness="1.5"
                                                  StrokeLineCap="Round" StrokeJoin="Round"/>
                                        </Viewbox>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="creds.yml" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="Open configuration" FontSize="11"
                                                       Foreground="{DynamicResource TextTertiary}"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Danger Zone -->
                <Border BorderBrush="{DynamicResource ErrorBorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Background="{DynamicResource ErrorBgSubtle}"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="DANGER ZONE" FontSize="11" FontWeight="Medium"
                                   Foreground="{DynamicResource ErrorColor}"
                                   LetterSpacing="1"/>
                        <TextBlock Text="Deleting this instance will remove all associated data and configuration files."
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <Button Classes="btn-danger-sm" Content="Delete Instance"
                                Command="{Binding ShowDeleteModalCommand}"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
