<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:upeko.ViewModels"
        xmlns:conv="using:upeko.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="700"
        x:Class="upeko.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Loc[MainWindow_Title]}"
        Width="960" Height="700"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/upeko.ico"
        Background="{DynamicResource AppBackground}">

    <Window.Resources>
        <conv:DepStatusToDotColorConverter x:Key="DepDotColor"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- Main Layout -->
        <DockPanel>
            <!-- Navigation Bar -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    Height="56">
                <Grid ColumnDefinitions="*,Auto" Margin="24,0">
                    <!-- Left: Logo + Version -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image Source="/Assets/upeko.ico" Width="20" Height="20"/>
                            <TextBlock Text="{DynamicResource App_Name}" FontWeight="SemiBold" FontSize="16"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0"
                                Padding="16,0,0,0" Height="24">
                            <TextBlock Text="{Binding CurrentVersion, StringFormat='v{0}'}" FontSize="11"
                                       Foreground="{DynamicResource TextTertiary}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Right: Deps + Theme Toggle -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                        <!-- ffmpeg indicator -->
                        <Button Classes="btn-ghost" Padding="6,4" MinHeight="0" MinWidth="0"
                                Command="{Binding InstallDepCommand}" CommandParameter="ffmpeg"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding FfmpegStatus, Converter={StaticResource DepDotColor}}"/>
                                <TextBlock Text="ffmpeg" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </Button>

                        <!-- yt-dlp indicator -->
                        <Button Classes="btn-ghost" Padding="6,4" MinHeight="0" MinWidth="0"
                                Command="{Binding InstallDepCommand}" CommandParameter="ytdlp"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding YtdlpStatus, Converter={StaticResource DepDotColor}}"/>
                                <TextBlock Text="yt-dlp" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </Button>

                        <!-- Minimize to Tray Toggle -->
                        <Button Classes="btn-ghost" Width="36" Height="36" Padding="0"
                                Command="{Binding ToggleMinimizeToTrayCommand}"
                                ToolTip.Tip="{DynamicResource MainWindow_MinimizeToTrayTip}">
                            <Panel>
                                <Viewbox Width="16" Height="16" IsVisible="{Binding MinimizeToTray}">
                                    <Path Data="M11.6490901,6.00190058 L11.7508607,5.99505396 C12.1305564,5.99505396 12.4443516,6.27720785 12.4940141,6.64328341 L12.5008607,6.74505396 L12.5,18.442 L16.2196501,14.7230771 C16.4859067,14.4568005 16.9025695,14.4325789 17.1961891,14.6504224 L17.2803103,14.7230374 C17.5465868,14.989294 17.5708084,15.4059568 17.3529649,15.6995764 L17.2803499,15.7836976 L12.2841108,20.7803103 C12.0180022,21.0464387 11.6016187,21.0708011 11.3079981,20.8532798 L11.2238679,20.7807668 L6.21901603,15.7841541 C5.92588163,15.4915023 5.92549043,15.0166287 6.21814226,14.7234943 C6.48418939,14.4570085 6.90083299,14.4324592 7.19462385,14.6500717 L7.27880207,14.7226205 L11,18.437 L11.0008607,6.74505396 C11.0008607,6.3653582 11.2830146,6.051563 11.6490901,6.00190058 L11.7508607,5.99505396 L11.6490901,6.00190058 Z M4.25,3 L19.25,3 C20.440864,3 21.4156449,3.92516159 21.4948092,5.09595119 L21.5,5.25 L21.5,16.754591 C21.5,17.945455 20.5748384,18.9202359 19.4040488,18.9994002 L19.25,19.004591 L18.2505177,19.004591 C17.8363042,19.004591 17.5005177,18.6688046 17.5005177,18.254591 C17.5005177,17.8748952 17.7826716,17.5611 18.1487472,17.5114376 L18.2505177,17.504591 L19.25,17.504591 C19.6296958,17.504591 19.943491,17.2224371 19.9931534,16.8563616 L20,16.754591 L20,5.25 C20,4.87030423 19.7178461,4.55650904 19.3517706,4.50684662 L19.25,4.5 L4.25,4.5 C3.87030423,4.5 3.55650904,4.78215388 3.50684662,5.14822944 L3.5,5.25 L3.5,16.754591 C3.5,17.1342868 3.78215388,17.448082 4.14822944,17.4977444 L4.25,17.504591 L5.25,17.504591 C5.66421356,17.504591 6,17.8403774 6,18.254591 C6,18.6342868 5.71784612,18.948082 5.35177056,18.9977444 L5.25,19.004591 L4.25,19.004591 C3.05913601,19.004591 2.08435508,18.0794294 2.00519081,16.9086398 L2,16.754591 L2,5.25 C2,4.05913601 2.92516159,3.08435508 4.09595119,3.00519081 L4.25,3 L19.25,3 L4.25,3 Z"
                                          Fill="{DynamicResource AccentColor}"
                                          Stretch="Uniform"/>
                                </Viewbox>
                                <Viewbox Width="16" Height="16" IsVisible="{Binding !MinimizeToTray}">
                                    <Path Data="M11.6490901,6.00190058 L11.7508607,5.99505396 C12.1305564,5.99505396 12.4443516,6.27720785 12.4940141,6.64328341 L12.5008607,6.74505396 L12.5,18.442 L16.2196501,14.7230771 C16.4859067,14.4568005 16.9025695,14.4325789 17.1961891,14.6504224 L17.2803103,14.7230374 C17.5465868,14.989294 17.5708084,15.4059568 17.3529649,15.6995764 L17.2803499,15.7836976 L12.2841108,20.7803103 C12.0180022,21.0464387 11.6016187,21.0708011 11.3079981,20.8532798 L11.2238679,20.7807668 L6.21901603,15.7841541 C5.92588163,15.4915023 5.92549043,15.0166287 6.21814226,14.7234943 C6.48418939,14.4570085 6.90083299,14.4324592 7.19462385,14.6500717 L7.27880207,14.7226205 L11,18.437 L11.0008607,6.74505396 C11.0008607,6.3653582 11.2830146,6.051563 11.6490901,6.00190058 L11.7508607,5.99505396 L11.6490901,6.00190058 Z M4.25,3 L19.25,3 C20.440864,3 21.4156449,3.92516159 21.4948092,5.09595119 L21.5,5.25 L21.5,16.754591 C21.5,17.945455 20.5748384,18.9202359 19.4040488,18.9994002 L19.25,19.004591 L18.2505177,19.004591 C17.8363042,19.004591 17.5005177,18.6688046 17.5005177,18.254591 C17.5005177,17.8748952 17.7826716,17.5611 18.1487472,17.5114376 L18.2505177,17.504591 L19.25,17.504591 C19.6296958,17.504591 19.943491,17.2224371 19.9931534,16.8563616 L20,16.754591 L20,5.25 C20,4.87030423 19.7178461,4.55650904 19.3517706,4.50684662 L19.25,4.5 L4.25,4.5 C3.87030423,4.5 3.55650904,4.78215388 3.50684662,5.14822944 L3.5,5.25 L3.5,16.754591 C3.5,17.1342868 3.78215388,17.448082 4.14822944,17.4977444 L4.25,17.504591 L5.25,17.504591 C5.66421356,17.504591 6,17.8403774 6,18.254591 C6,18.6342868 5.71784612,18.948082 5.35177056,18.9977444 L5.25,19.004591 L4.25,19.004591 C3.05913601,19.004591 2.08435508,18.0794294 2.00519081,16.9086398 L2,16.754591 L2,5.25 C2,4.05913601 2.92516159,3.08435508 4.09595119,3.00519081 L4.25,3 L19.25,3 L4.25,3 Z"
                                          Fill="{DynamicResource TextTertiary}"
                                          Stretch="Uniform"/>
                                </Viewbox>
                            </Panel>
                        </Button>

                        <!-- Theme Toggle -->
                        <Button Classes="btn-ghost" Width="36" Height="36" Padding="0"
                                Command="{Binding ToggleThemeCommand}"
                                ToolTip.Tip="{DynamicResource MainWindow_ToggleThemeTip}">
                            <Panel>
                                <Viewbox Width="16" Height="16" IsVisible="{Binding !IsDarkTheme}">
                                    <Path Data="M12 3V4M12 20V21M21 12H20M4 12H3M18.364 18.364L17.657 17.657M6.343 6.343L5.636 5.636M18.364 5.636L17.657 6.343M6.343 17.657L5.636 18.364M16 12A4 4 0 1 1 8 12A4 4 0 0 1 16 12Z"
                                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                </Viewbox>
                                <Viewbox Width="16" Height="16" IsVisible="{Binding IsDarkTheme}">
                                    <Path Data="M20.354 15.354A9 9 0 0 1 8.646 3.646A9.003 9.003 0 0 0 12 21A9.003 9.003 0 0 0 20.354 15.354Z"
                                          Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                </Viewbox>
                            </Panel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Footer Bar -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,1,0,0"
                    Height="36">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                    <!-- Left: Discord -->
                    <Button Grid.Column="0" Classes="btn-ghost" Padding="0" MinHeight="0" MinWidth="0"
                            Command="{Binding OpenDiscordCommand}"
                            ToolTip.Tip="{DynamicResource MainWindow_DiscordTip}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Viewbox Width="18" Height="18">
                            <Path Data="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"
                                  Fill="#5865F2"
                                  Stretch="Uniform"/>
                        </Viewbox>
                    </Button>

                    <!-- Language Selector (left, next to Discord) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left"
                                VerticalAlignment="Stretch" Spacing="0">
                        <Border Width="1" Background="{DynamicResource BorderColor}"
                                Margin="24,0,0,0"/>
                        <TextBlock Text="文" FontSize="14"
                                   Foreground="{DynamicResource TextTertiary}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguageOption}"
                                  MinWidth="100"
                                  MaxDropDownHeight="300"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="4,0"
                                  VerticalAlignment="Center"
                                  FontSize="12">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LanguageOption">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                               Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Right: Version or Update pill -->
                    <TextBlock Grid.Column="2"
                               IsVisible="{Binding !IsUpEkoUpdateAvailable}"
                               Text="{Binding CurrentVersion, StringFormat='v{0}'}"
                               VerticalAlignment="Center"
                               Opacity="0.5"
                               FontSize="11"
                               Foreground="{DynamicResource TextTertiary}"/>

                    <Button Grid.Column="2"
                            IsVisible="{Binding IsUpEkoUpdateAvailable}"
                            Command="{Binding OpenUpEkoReleaseCommand}"
                            Background="#4CBB17"
                            Foreground="White"
                            Padding="10,2"
                            CornerRadius="12"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="{DynamicResource MainWindow_NewerVersionTip}">
                        <TextBlock Text="{DynamicResource MainWindow_NewerVersion}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="Medium"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding CurrentView}"
                                Margin="24,40,24,40"
                                MaxWidth="960"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Stretch"/>
            </ScrollViewer>
        </DockPanel>

        <!-- Toast Notification -->
        <Border IsVisible="{Binding IsToastVisible}"
                Background="{DynamicResource AppBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                MaxWidth="300"
                BoxShadow="0 2 8 0 #20000000">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="#0070f3"/>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="{Binding ToastMessage}" FontSize="13" FontWeight="Medium"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Delete Modal Overlay -->
        <Border IsVisible="{Binding IsDeleteModalOpen}"
                Background="#66000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="8"
                    MaxWidth="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="24"
                    BoxShadow="0 4 16 0 #40000000">
                <StackPanel Spacing="8">
                    <TextBlock Text="{DynamicResource Modal_DeleteTitle}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="{Binding DeleteModalMessage}"
                               TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                        <Button Classes="btn-ghost"
                                Content="{DynamicResource Modal_Cancel}"
                                Command="{Binding CancelDeleteCommand}"/>
                        <Button Classes="btn-danger"
                                Content="{DynamicResource Modal_Delete}"
                                Command="{Binding ConfirmDeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Exit Confirmation Modal Overlay -->
        <Border IsVisible="{Binding IsExitModalOpen}"
                Background="#66000000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Background="{DynamicResource AppBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="8"
                    MaxWidth="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="24"
                    BoxShadow="0 4 16 0 #40000000">
                <StackPanel Spacing="8">
                    <TextBlock Text="{DynamicResource Modal_ExitTitle}" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="{Binding ExitModalMessage}"
                               TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                        <Button Classes="btn-ghost"
                                Content="{DynamicResource Modal_Cancel}"
                                Command="{Binding CancelExitCommand}"/>
                        <Button Classes="btn-danger"
                                Content="{DynamicResource Modal_QuitAnyway}"
                                Command="{Binding ConfirmExitCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</Window>
